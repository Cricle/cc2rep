{
  "proxy_host": "127.0.0.1",
  "proxy_port": 8800,
  "proxy_api_key": "proxy-secret",
  "upstream_base_url": "https://api.example.com",
  "upstream_chat_path": "/v1/chat/completions",
  "upstream_model": "deepseek-chat",
  "upstream_api_key": "upstream-secret",
  "upstream_headers": {},
  "upstream_body": {},
  "upstream_api_key_header_name": "Authorization",
  "upstream_api_key_prefix": "Bearer ",
  "request_timeout_seconds": 120.0,
  "strict_protocol": false,
  "upstream_supports_image_input": false,
  "drop_input_reasoning": false,
  "drop_tools": false,
  "response_ttl_seconds": 3600,
  "max_auto_tool_rounds": 8,
  "upstream_max_retries": 3,
  "upstream_retry_base_delay_ms": 1000,
  "local_tools": {
    "echo_json": {
      "command": "sh",
      "args": [
        "-lc",
        "cat"
      ],
      "env": {},
      "workdir": null,
      "timeout_seconds": 10.0,
      "stdin_json": true,
      "output_json": true
    }
  },
  "model_aliases": {
    "gpt-5-codex": "deepseek-chat"
  }
}
